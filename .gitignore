```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
venv/
.venv/

# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
*.env.*

# Coverage reports
coverage/
htmlcov/
.coverage

# Python cache
.mypy_cache/
.pytest_cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Build directories
build/
dist/
*.egg-info/

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db
```